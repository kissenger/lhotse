    "@paypal/paypal-server-sdk",
    "@types/bcrypt",
    "@types/mapbox-gl",
    "body-parser",
    "sharp",
    "@angular-devkit/architect",
    "@angular-devkit/build-webpack",
    "@angular-devkit/core",
