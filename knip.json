{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": [
    "src/**/*.{ts,js}",
    "schema/**/*.{ts,js}",
    "tests/**/*.{ts,js}",
    "tools/**/*.{js,mjs}"
  ],
  "ignore": [
    "src/test.ts",
    "tools/generate-sitemap.mjs",
    "tools/regenerate-og-images.mjs",
    "tools/run-e2e.mjs",
