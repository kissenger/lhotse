{
  "name": "lhotse",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng  serve",
    "serve": "node --watch ./dist/dev/server/server.mjs",
    "serve:prod": "node ./dist/prod/server/server.mjs",
    "serve:beta": "node ./dist/beta/server/server.mjs",
    "watch:ssr": "ng build --watch --configuration development",
    "build:master": "ng build --configuration prod",
    "build:beta": "ng build --configuration beta",
    "pull": "bash ./tools/pull.sh",
    "pull:beta": "bash ./tools/pull.sh beta",
    "pull:master": "bash ./tools/pull.sh master",
    "deploy:beta": "bash ./tools/deploy.sh beta",
    "deploy:master": "bash ./tools/deploy.sh master",
    "test:seo": "node ./tests/test-seo.js",
    "test:paypal": "node ./tests/test-paypal-integration.js",
    "test:shop-backend": "node ./tests/test-shop-backend-integration.js",
    "og:backfill": "node ./tools/backfill-blog-og-images.mjs",
    "sitemap:generate": "node ./tools/generate-sitemap.mjs",
    "sitemap:nightly": "bash ./tools/run-sitemap-nightly.sh",
    "test:ui": "playwright test",
    "test:ui:node": "node ./tools/run-e2e.mjs",
    "test:ui:mobile": "playwright test --project=chromium --project=webkit --project=iphone-chromium-emulation --project=iphone-safari-webkit",
    "test:ui:paypal": "playwright test tests/e2e/paypal-ui.spec.js",
    "test:ui:paypal:sandbox": "playwright test tests/e2e/paypal-sandbox-nightly.spec.js",
    "test:ui:dead-links": "playwright test tests/e2e/dead-links.spec.js",
    "test:ui:mongo-connectivity": "playwright test tests/e2e/mongo-connectivity.spec.js",
    "test:ui:performance": "playwright test tests/e2e/performance.spec.js",
    "test:all": "npm run test && npm run test:seo && npm run test:shop-backend && npm run test:dead-code && npm run test:ui",
    "test:dead-code": "node ./tests/test-dead-code.js",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.0.0",
    "@angular/cli": "^21.2.0",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/platform-server": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/ssr": "^21.2.0",
    "@paypal/paypal-js": "^8.1.3",
    "@paypal/paypal-server-sdk": "^0.6.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mapbox-gl": "^3.4.1",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "glob": "^13.0.6",
    "jsonwebtoken": "^9.0.2",
    "mapbox-gl": "^3.13.0",
    "mongoose": "^8.5.1",
    "nodemailer": "^8.0.1",
    "rxjs": "~7.8.0",
    "sharp": "^0.34.4",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular-devkit/build-webpack": "^0.2102.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/compiler-cli": "^21.2.7",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.52.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^6.4.17",
    "baseline-browser-mapping": "^2.9.15",
    "copy-webpack-plugin": "^14.0.0",
    "jasmine-core": "~5.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "playwright": "^1.52.0",
    "source-map-explorer": "^2.5.3",
    "tsx": "^4.19.4",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "webpack": "^5.105.3"
  }
}
